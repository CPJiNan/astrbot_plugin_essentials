{
  "permission": {
    "description": "权限模块配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "是否启用权限模块",
        "type": "bool",
        "default": true
      },
      "proxy": {
        "description": "权限代理",
        "type": "object",
        "items": {
          "enabled": {
            "description": "是否启用权限代理",
            "type": "bool",
            "default": false
          },
          "rules": {
            "description": "规则列表",
            "type": "template_list",
            "templates": {
              "keywords": {
                "name": "关键词匹配",
                "items": {
                  "name": {
                    "description": "规则名称",
                    "type": "string",
                    "default": ""
                  },
                  "enabled": {
                    "description": "是否启用规则",
                    "type": "bool",
                    "default": true
                  },
                  "keywords": {
                    "description": "关键词列表",
                    "type": "list",
                    "default": []
                  },
                  "node": {
                    "description": "所需权限节点",
                    "type": "string",
                    "default": ""
                  }
                }
              }
            }
          }
        }
      },
      "cache_default_expiry": {
        "description": "默认权限缓存过期时间（秒）",
        "type": "int",
        "default": 300
      }
    }
  },
  "placeholder": {
    "description": "占位符模块配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "是否启用占位符模块",
        "type": "bool",
        "default": true
      },
      "prefix": {
        "description": "占位符前缀",
        "type": "string",
        "default": "%"
      },
      "suffix": {
        "description": "占位符后缀",
        "type": "string",
        "default": "%"
      },
      "parse_message": {
        "description": "是否解析消息中的占位符",
        "type": "bool",
        "default": true
      }
    }
  },
  "economy": {
    "description": "经济模块配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "是否启用经济模块",
        "type": "bool",
        "default": true
      },
      "cache_default_expiry": {
        "description": "默认经济缓存过期时间（秒）",
        "type": "int",
        "default": 300
      }
    }
  }
}
