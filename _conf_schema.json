{
  "permission_enabled": {
    "description": "是否启用权限模块",
    "type": "bool",
    "default": true
  },
  "webeditor_enabled": {
    "description": "是否启用网页编辑器",
    "type": "bool",
    "default": true
  },
  "webeditor_host": {
    "description": "网页编辑器地址",
    "type": "string",
    "default": "127.0.0.1"
  },
  "webeditor_port": {
    "description": "网页编辑器端口",
    "type": "int",
    "default": 25560
  },
  "placeholder_enabled": {
    "description": "是否启用占位符模块",
    "type": "bool",
    "default": true
  },
  "placeholder_prefix": {
    "description": "占位符前缀",
    "type": "string",
    "default": "%"
  },
  "placeholder_suffix": {
    "description": "占位符后缀",
    "type": "string",
    "default": "%"
  },
  "cache_default_expiry": {
    "description": "默认缓存过期时间（秒）",
    "type": "int",
    "default": 300
  }
}